{
  "compilerOptions": {
    "target": "ES2017",
    "module": "none",
    "lib": ["ES2017", "DOM", "DOM.Iterable"],
    "checkJs": true,
    "strict": false,
    "noEmit": true,
    "allowJs": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "typeRoots": []
  },
  "include": ["*.js"],
  "exclude": ["node_modules"]
}
